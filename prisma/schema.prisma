generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Ride {
  id          Int      @id @default(autoincrement())
  pickup      String
  dropoff     String
  date        String?
  time        String?
  passengers  Int      @default(1)
  driverName  String   @default("Anonymous")
  price       Int      @default(0)
  rating      String   @default("5.0")
  createdAt   DateTime @default(now())
}

model Booking {
  id          Int      @id @default(autoincrement())
  rideId      Int
  passenger   String   @default("Guest")
  seats       Int      @default(1)
  totalPrice  Int      @default(0)
  status      String   @default("Confirmed")
  createdAt   DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}
